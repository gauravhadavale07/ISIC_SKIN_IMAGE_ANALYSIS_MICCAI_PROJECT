digraph G {
    rankdir=LR;
    fontname="Helvetica,Arial,sans-serif";
    splines=spline;
    nodesep=0.4;
    ranksep=0.7;
    
    node [fontname="Helvetica,Arial,sans-serif", shape=box, style="rounded,filled", fillcolor="#ffffff", color="#d1d5db", penwidth=1.5, margin="0.2,0.1", fontsize=11];
    edge [fontname="Helvetica,Arial,sans-serif", color="#9ca3af", penwidth=1.5, arrowsize=0.8];

    subgraph cluster_input {
        label = "1. Input Modalities";
        style="rounded,filled";
        fillcolor="#f3f4f6";
        color="#e5e7eb";
        fontname="Helvetica-Bold";
        fontsize=12;
        margin=20;
        Img [label="Skin Lesion Image\n(Dermoscopic)", fillcolor="#dbeafe", color="#93c5fd"];
        Txt [label="Clinical History Text\n(Metadata)", fillcolor="#dbeafe", color="#93c5fd"];
    }

    subgraph cluster_probes {
        label = "2. Mechanistic Probes (Text Pathway)";
        style="rounded,filled";
        fillcolor="#fef3c7";
        color="#fde68a";
        fontname="Helvetica-Bold";
        fontsize=12;
        margin=20;
        P1 [label="A. Real Text Baseline", fillcolor="#ffffff", color="#fbbf24"];
        P2 [label="B. Blank-Text Ablation", fillcolor="#ffffff", color="#fbbf24"];
        P3 [label="C. Neutral Text Probe", fillcolor="#ffffff", color="#fbbf24"];
        P4 [label="D. Counterfactual Override", fillcolor="#ffffff", color="#fbbf24"];
        P5 [label="E. Metadata-Shuffle", fillcolor="#ffffff", color="#fbbf24"];
    }

    subgraph cluster_model {
        label = "3. Multimodal Architecture";
        style="rounded,filled";
        fillcolor="#f3f4f6";
        color="#e5e7eb";
        fontname="Helvetica-Bold";
        fontsize=12;
        margin=20;
        Fusion [label="Cross-Modal Fusion Layer\n(Late / GMU / Cross-Attention)", fillcolor="#dcfce7", color="#86efac", shape=rect, style="rounded,filled"];
    }

    subgraph cluster_metrics {
        label = "4. Integrity Verification Metrics";
        style="rounded,filled";
        fillcolor="#f5f3ff";
        color="#ede9fe";
        fontname="Helvetica-Bold";
        fontsize=12;
        margin=20;
        M1 [label="Accuracy Drop\n(P1 vs P3)", fillcolor="#ffffff", color="#c4b5fd"];
        M2 [label="Counterfactual Flip Rate\n(P1 vs P4)", fillcolor="#ffffff", color="#c4b5fd"];
        M3 [label="Linear CKA\n(Visual vs Fused)", fillcolor="#ffffff", color="#c4b5fd"];
        M4 [label="Lexical Dependency\n(P1 vs P5)", fillcolor="#ffffff", color="#c4b5fd"];
    }

    Img -> Fusion [weight=10];
    Txt -> P1 [style=dashed];
    Txt -> P2 [style=dashed];
    Txt -> P3 [style=dashed];
    Txt -> P4 [style=dashed];
    Txt -> P5 [style=dashed];
    
    P1 -> Fusion;
    P2 -> Fusion;
    P3 -> Fusion;
    P4 -> Fusion;
    P5 -> Fusion;

    Fusion -> M1;
    Fusion -> M2;
    Fusion -> M3;
    Fusion -> M4;
}
